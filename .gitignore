*.local

# Locally-generated artifacts that should never be committed
public/uploads/
uploads/
screenshots/
*.cache/
.parcel-cache

# Sensitive defaults — never check in real values
*.pem
*.key
*.crt
secrets/

# Private ritual media — deploy manually, don't commit personal files
public/ritual/*.mp4
public/ritual/*.jpg
public/ritual/*.jpeg
public/ritual/*.png
