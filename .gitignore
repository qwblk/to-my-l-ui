# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Builds / deps
node_modules
dist
dist-ssr
.vite/
*.tsbuildinfo

# Local-only env files. .env.example is the committed reference.
.env
.env.*
!.env.example

