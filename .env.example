# === Public, build-time SPA configuration ===
# Vite only inlines variables prefixed with VITE_ into the bundle.
# Copy this file to .env (and/or .env.production) and adjust.

# Where the SPA talks to the backend. In production keep "/api" so nginx
# reverse-proxies; in dev you can leave it empty to let Vite's proxy do
# the work, or set an absolute URL to bypass the proxy.
VITE_API_BASE=/api

# WebSocket origin. Leave empty to use the same origin as the page
# (which makes nginx /ws/ proxy work). Set to ws://host:port for direct
# connections.
VITE_WS_BASE=

# Display names. Pure cosmetic, never sent to the backend; the IDs
# below decide which name belongs to whom.
VITE_CURRENT_USER_ID=1
VITE_PARTNER_USER_ID=2
VITE_CURRENT_USER_NAME=王水群
VITE_PARTNER_USER_NAME=潘佩雪

# Optional comma-separated alias usernames for matching the welcome
# letter on first login. The display names above are always matched
# automatically (case-insensitive); this list adds extra aliases like
# system usernames. Example:
#   VITE_CURRENT_USERNAMES=bob,wsq
#   VITE_PARTNER_USERNAMES=alice,ppx
VITE_CURRENT_USERNAMES=
VITE_PARTNER_USERNAMES=

# Anchor dates.
VITE_SINCE_DATE=2026-05-24
VITE_PARTNER_BIRTHDAY_MMDD=03-22

# === Local-dev only ===
# Vite dev server proxies /api, /ws, /upload, /static to this origin.
# Not read by the production build.
VITE_DEV_BACKEND_ORIGIN=http://localhost:8081

# === Compose deploy options ===
FRONTEND_HOST_PORT=5173
